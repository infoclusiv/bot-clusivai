[Unit]
Description=Clusivai ngrok Tunnel
After=network.target clusivai-webapp.service
Requires=clusivai-webapp.service

[Service]
Type=simple
User=clusiv
WorkingDirectory=/home/clusiv/bot-clusivai
ExecStart=/usr/bin/env bash /home/clusiv/bot-clusivai/start-ngrok.sh
Restart=always
RestartSec=5
EnvironmentFile=/home/clusiv/bot-clusivai/.env

[Install]
WantedBy=multi-user.target